# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Pooled connection used by the app at runtime (PgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma migrations (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ── Encryption (Plaid token at rest, AES-256-GCM — exactly 32 decoded bytes) ──
# Generate base64 with: openssl rand -base64 32
ENCRYPTION_KEY="base64-32-byte-secret"

# ── Redis (Upstash) ───────────────────────────────────────────────────────
REDIS_URL="rediss://default:PASSWORD@HOST:6379"

# ── AI providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
CATEGORIZATION_MODEL="claude-haiku-4-5"
CATEGORIZE_BATCH_SIZE="25"
OPENAI_API_KEY=""

# ── Plaid (sandbox) ───────────────────────────────────────────────────────
# Used for Link, transactions sync, and webhook verification-key retrieval.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# ── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"

# ── Web app / BFF ─────────────────────────────────────────────────────────
# Browser-facing API base. Default routes through the Next thin BFF.
NEXT_PUBLIC_API_URL="/api"
# Server-side Express API origin used by apps/web route handlers.
API_UPSTREAM_URL="http://localhost:4000"
