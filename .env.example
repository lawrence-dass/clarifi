# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Pooled connection used by the app at runtime (PgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma migrations (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Optional: ISOLATED database for the test suite (vitest). When set, DB-backed
# tests run here instead of DATABASE_URL — point it at a throwaway local Postgres
# so the suite never shares rows with the dev DB or a live worker (which would
# make exact-count assertions flaky). Run migrations against it first.
# TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
# TEST_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ── Encryption (Plaid token at rest, AES-256-GCM — exactly 32 decoded bytes) ──
# Generate base64 with: openssl rand -base64 32
ENCRYPTION_KEY="base64-32-byte-secret"

# ── Redis (Upstash) — BullMQ workers connect over TCP (ioredis) ───────────
# Use the TCP connection string (rediss://, TLS, port 6379) from the Upstash
# console's Redis/ioredis connection details.
# ⚠️ NOT the REST API: UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# (the https:// HTTP client) are NOT used by this app — BullMQ requires a
# persistent TCP connection, so it must be REDIS_URL below.
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:6379"

# ── AI providers ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY is required for transaction categorization (worker),
# natural-language query, and anomaly explanations. Without it those 500/fail.
ANTHROPIC_API_KEY="sk-ant-..."
CATEGORIZATION_MODEL="claude-haiku-4-5"
CATEGORIZE_BATCH_SIZE="25"
OPENAI_API_KEY=""

# ── Plaid (sandbox) ───────────────────────────────────────────────────────
# Used for Link, transactions sync, and webhook verification-key retrieval.
#
# Also gates the Plaid half of the public demo (Story 12.1): with these set,
# `POST /demo/session` seeds a Plaid Sandbox account + transactions alongside
# the bundled sample CSV. Left empty, the demo still works but degrades to
# CSV-only (graceful — no error). Get sandbox keys (client_id + the Sandbox
# secret) from https://dashboard.plaid.com/developers/keys; keep PLAID_ENV=sandbox.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# ── Demo abuse & cost controls (Story 12.2) ───────────────────────────────
# Cloudflare Turnstile secret (server). Unset → the bot-gate bypasses (dev/CI);
# set → POST /demo/session and demo NL-queries are challenge-gated. The matching
# PUBLIC site key goes in the web app env as NEXT_PUBLIC_TURNSTILE_SITE_KEY
# (apps/web/.env.local). Get both from the Cloudflare dashboard → Turnstile.
TURNSTILE_SECRET_KEY=""
# Per-demo-session NL-query quota + per-IP rate limits (Redis). Defaults are sane;
# override to tune. The TTL reaper (worker) sweeps expired demo users.
DEMO_SESSION_NL_QUOTA="10"
DEMO_MINT_RATE_LIMIT="10"
DEMO_MINT_RATE_WINDOW_SEC="3600"
DEMO_NL_RATE_LIMIT="60"
DEMO_NL_RATE_WINDOW_SEC="3600"
DEMO_REAP_INTERVAL_MS="300000"
DEMO_REAP_BATCH="100"

# ── Runtime ───────────────────────────────────────────────────────────────
# Three processes use this file: the API (pnpm --filter @clarifi/api dev),
# the BullMQ worker (pnpm --filter @clarifi/api worker — categorization,
# anomaly detection/explanation, digests), and the web app. `pnpm dev` starts
# the api + web but NOT the worker — run the worker separately or categories,
# merchants, and anomalies stay empty.
NODE_ENV="development"
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"

# ── Web app / BFF ─────────────────────────────────────────────────────────
# ⚠️ Next.js loads env from the app dir (apps/web/), NOT this monorepo-root
# .env. These two MUST live in apps/web/.env.local or the web app can't reach
# the API (NEXT_PUBLIC_API_URL undefined → "Something went wrong", no request).
# Browser-facing API base. Default routes through the Next thin BFF proxy.
NEXT_PUBLIC_API_URL="/api"
# Server-side Express API origin the BFF proxies to.
API_UPSTREAM_URL="http://localhost:4000"
