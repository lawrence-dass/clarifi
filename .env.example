# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Pooled connection used by the app at runtime (PgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma migrations (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ── Encryption (Plaid token at rest, AES-256-GCM — 32-byte key, hex = 64 chars) ──
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ── Redis (Upstash) ───────────────────────────────────────────────────────
REDIS_URL="rediss://default:PASSWORD@HOST:6379"

# ── AI providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
CATEGORIZATION_MODEL="claude-haiku-4-5"
CATEGORIZE_BATCH_SIZE="25"
OPENAI_API_KEY=""

# ── Plaid (sandbox) ───────────────────────────────────────────────────────
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# ── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"
