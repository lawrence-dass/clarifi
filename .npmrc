# Run workspace scripts one package at a time. The DB-integration test suites
# (shared RLS, api auth) all hit the same Supabase instance; running packages in
# parallel causes connection/transaction contention and flaky failures. Serial
# execution keeps `pnpm -r test` (and build/typecheck) deterministic. The repo is
# small, so the wall-clock cost is negligible.
workspace-concurrency=1
